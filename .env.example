# ─── LLM 配置 ──────────────────────────────────────────────────────────────
# Friday App ID（API 认证）
FRIDAY_APP_ID=xxx

# 默认模型
LLM_MODEL=xxx

# 默认参数
LLM_TEMPERATURE=0.1
LLM_TOP_P=1
LLM_MAX_TOKENS=4096

# API 端点
LLM_BASE_URL=https://aigc.sankuai.com/v1/openai/native/chat/completions

